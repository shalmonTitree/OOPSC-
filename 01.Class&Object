#include <bits/stdc++.h>
using namespace std;

class Teacher{
    private:
        double salary;
    public:
        //properties / attributes 
        string name;
        string dept;
        string subject;
    

    //methods or functions // member functions 

    void changeDept(string newDept)
    {
        dept = newDept;
    }

    //setter: useful for setting the private values 
    void setSalary(double s)
    {
        salary = s;
    }
    //getter: usefull for getting the value of private value 
    double getSalary()
    {
        return salary;
    }
};

int main() {
    Teacher t1;
    t1.name = "Shalmon Titre";
    t1.dept = "IT";
    t1.subject = "NLP";
    t1.setSalary(25000);


    cout<<t1.name<<endl;
    cout<<t1.dept<<endl;
    cout<<t1.subject<<endl;
    cout<<t1.getSalary()<<endl;

    
    t1.changeDept("CSE");
    cout<<t1.dept<<endl;
   

    return 0;
}
