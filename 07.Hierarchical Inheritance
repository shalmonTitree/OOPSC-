#include <bits/stdc++.h>
using namespace std;

// Base Class
class A {
public:
    void showA() {
        cout << "Class A" << endl;
    }
};

// Derived Class B
class B : public A {
public:
    void showB() {
        cout << "Class B" << endl;
    }
};

// Derived Class C
class C : public A {
public:
    void showC() {
        cout << "Class C" << endl;
    }
};

int main() {

    B obj1;
    obj1.showA();
    obj1.showB();

    C obj2;
    obj2.showA();
    obj2.showC();

    return 0;
}
