#include <iostream>
using namespace std;

// Parent Class
class Parent {
public:
    void show() {
        cout << "This is Parent class" << endl;
    }
};

// Child Class
class Child : public Parent {
public:
    void show() {
        cout << "This is Child class" << endl;
    }
};

int main() {

    Child obj;

    obj.show();

    return 0;
}
