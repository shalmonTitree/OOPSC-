#include <iostream>
using namespace std;

// Parent class
class Person {
public:
    string name;
    int age;

    void displayPerson() {
        cout << "Name: " << name << endl;
        cout << "Age: " << age << endl;
    }
};

// Child class
class Student : public Person {
public:
    int rollNo;

    void displayStudent() {
        cout << "Roll Number: " << rollNo << endl;
    }
};

int main() {
    Student s1;

    // Inherited attributes
    s1.name = "Rahul";
    s1.age = 20;

    // Student attribute
    s1.rollNo = 101;

    s1.displayPerson();
    s1.displayStudent();

    return 0;
}
