#include <bits/stdc++.h>
using namespace std;

class Teacher
{
private:
    double salary;

public:    

    string name;
    string dept;
    string subject;

    Teacher(string n,string d,string s)
    {
        name = n;
        dept = d;
        subject = s;
    }

    //copy construtor
     Teacher(const Teacher &obj)
    {
        cout << "Custom Copy Constructor Called" << endl;

        name = obj.name;
        dept = obj.dept;
        subject = obj.subject;
        salary = obj.salary;
    }
    void changeDept(string newDept)
    {
        dept = newDept;
    }

    void setSalary(double s)
    {
        salary = s;
    }
    double getSalary()
    {
        return salary;
    }
};

int main()
{
    Teacher t1("Shalmon","IT","NLP");
    Teacher t2(t1);

    cout << t2.name << endl;
    cout << t2.dept << endl;
    cout << t2.subject << endl;

    return 0;
}
