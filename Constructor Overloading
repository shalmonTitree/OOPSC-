#include <bits/stdc++.h>
using namespace std;

class Student {
public:
    string name;
    int age;

    // Default constructor
    Student() {
        name = "Unknown";
        age = 0;
    }

    // Constructor with one parameter
    Student(string n) {
        name = n;
        age = 0;
    }

    // Constructor with two parameters
    Student(string n, int a) {
        name = n;
        age = a;
    }

    void display() {
        cout << name << " " << age << endl;
    }
};

int main() {

    Student s1;
    Student s2("Rahul");
    Student s3("Aman", 20);

    s1.display();
    s2.display();
    s3.display();

    return 0;
}
